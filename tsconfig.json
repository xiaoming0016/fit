{
  "compilerOptions": {
    "target": "ES2021",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "allowJs": false,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
